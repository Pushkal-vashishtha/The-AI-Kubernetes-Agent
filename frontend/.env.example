# Base URL of the backend API (Vite exposes only VITE_-prefixed vars to the app)
VITE_API_BASE_URL=http://localhost:8000

# InsForge (anon key is public by design — safe in frontend env)
# URL: `oss_host` in .insforge/project.json; anon key: `npx @insforge/cli secrets get ANON_KEY`
VITE_INSFORGE_URL=
VITE_INSFORGE_ANON_KEY=
