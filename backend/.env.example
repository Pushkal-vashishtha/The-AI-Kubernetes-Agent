# Server
PORT=8000

# OpenRouter (key provided via InsForge — keep server-only, never commit)
OPENROUTER_API_KEY=
# Optional: defaults to anthropic/claude-sonnet-4.5
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Kubernetes: path to a kubeconfig file (optional; defaults to kubectl's normal config)
KUBECONFIG_PATH=

# InsForge (server-only admin credentials — never expose to the frontend)
# URL: `oss_host` in .insforge/project.json; API key: `api_key` in the same file
INSFORGE_URL=
INSFORGE_API_KEY=
